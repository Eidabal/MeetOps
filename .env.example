# ──────────────────────────────────────────────
# MeetOps · Variables d'environnement (TEMPLATE)
# Copier ce fichier en .env.local et renseigner les valeurs.
# .env.local n'est JAMAIS committé (voir .gitignore).
# ──────────────────────────────────────────────

# --- Supabase (client-safe, préfixe VITE_ requis pour être exposé au front) ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Anthropic (SERVEUR UNIQUEMENT — jamais de préfixe VITE_) ---
# En cible, cette clé ne vit que dans les Supabase Edge Functions.
# Ne JAMAIS l'exposer côté client.
ANTHROPIC_API_KEY=

# --- OpenAI Whisper (transcription audio — serveur uniquement) ---
OPENAI_API_KEY=

# --- Optionnel ---
VITE_APP_ENV=development